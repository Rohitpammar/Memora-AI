{
  "info": {
    "name": "Memora AI API",
    "description": "Complete API collection for Memora AI backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload",
              "host": ["{{base_url}}"],
              "path": ["upload"]
            }
          }
        }
      ]
    },
    {
      "name": "Memories",
      "item": [
        {
          "name": "Get Memory Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/memories/stats",
              "host": ["{{base_url}}"],
              "path": ["memories", "stats"]
            }
          }
        },
        {
          "name": "Query Memories",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"your query here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/memories/query",
              "host": ["{{base_url}}"],
              "path": ["memories", "query"]
            }
          }
        }
      ]
    },
    {
      "name": "Graph",
      "item": [
        {
          "name": "Read Graph",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/graph",
              "host": ["{{base_url}}"],
              "path": ["graph"]
            }
          }
        }
      ]
    }
  ]
}